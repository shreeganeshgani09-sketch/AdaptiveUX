{
  "manifest_version": 3,
  "name": "Smart Adaptive Interface",
  "version": "1.0.0",
  "description": "Your context-aware action assistant, available instantly on any domain.",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Open SAI"
  },
  "permissions": [
    "storage"
  ],
  "host_permissions": [
    "<all_urls>"
  ],
  "icons": {
    "128": "icon.png"
  }
}